{
  "name": "black-mango-desktop",
  "version": "1.1.2",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "castv2-client": "^1.2.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "mdns-js": "^1.0.3",
    "node-ssdp": "^4.0.1",
    "node-upnp-utils": "^1.0.3"
  },
  "build": {
    "appId": "com.blackmango.desktop",
    "productName": "Black Mango",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "icon": "build/icon.png",
    "publish": [
      {
        "provider": "github",
        "owner": "Chadloz",
        "repo": "darkflix"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Chadloz/darkflix"
  }
}